---
/**
 * MapOverlay: Renders clickable hotspots over the world map image.
 * Each hotspot is positioned via CSS percentage coordinates from location frontmatter.
 */
interface MapLocation {
  id: string;
  name: string;
  mapX: number;
  mapY: number;
  region?: string;
}

interface Props {
  locations: MapLocation[];
}

const { locations } = Astro.props;
---

<div class="map-container" id="map-container">
  <div class="map-wrapper" id="map-wrapper">
    <img
      src="/images/world-map.png.png"
      alt="World Map"
      class="map-image"
      id="map-image"
      draggable="false"
    />

    {locations.map((loc) => (
      <a
        href={`/locations/${loc.id}/`}
        class="map-hotspot"
        data-name={loc.name}
        data-region={loc.region || ''}
        data-map-x={loc.mapX}
        data-map-y={loc.mapY}
      >
        <svg class="map-hotspot__shield" viewBox="0 0 10 18" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <path d="M5 1 C7.5 3 8.5 6 8 9 C7.6 11 6.5 12.5 5.3 13.5 L5.3 17 L4.7 17 L4.7 13.5 C3.5 12.5 2.4 11 2 9 C1.5 6 2.5 3 5 1 Z" />
          <path d="M5 3 L5 13" stroke="rgba(220, 200, 170, 0.5)" stroke-width="0.4" fill="none" />
        </svg>
        <span class="map-hotspot__label">{loc.name}</span>
      </a>
    ))}
  </div>

  <div class="map-controls">
    <button class="map-controls__btn" id="zoom-in" aria-label="Zoom in">+</button>
    <button class="map-controls__btn" id="zoom-out" aria-label="Zoom out">−</button>
    <button class="map-controls__btn" id="zoom-reset" aria-label="Reset zoom">⟲</button>
  </div>

  <div class="map-tooltip" id="map-tooltip"></div>
</div>

<style>
  .map-container {
    position: relative;
    width: 100%;
    height: calc(100vh - var(--nav-height) - 80px);
    min-height: 500px;
    overflow: hidden;
    border-radius: var(--border-radius-lg);
    border: 1px solid var(--color-border);
    background: var(--color-bg-card);
    cursor: grab;
  }

  .map-container:active {
    cursor: grabbing;
  }

  .map-wrapper {
    position: relative;
    width: 100%;
    height: 100%;
    transform-origin: 0 0;
    transition: transform 0.1s ease-out;
  }

  .map-image {
    width: 100%;
    height: 100%;
    object-fit: contain;
    user-select: none;
    pointer-events: none;
  }

  /* --- Hotspots --- */
  .map-hotspot {
    position: absolute;
    transform: translate(-50%, -50%);
    text-decoration: none;
    z-index: 10;
    opacity: 0;
    width: 10px;
    height: 18px;
    transition: opacity var(--transition-fast), transform var(--transition-fast);
  }

  .map-hotspot--ready {
    opacity: 1;
  }

  .map-hotspot__shield {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    fill: rgba(42, 37, 32, 0.82);
    stroke: rgba(180, 160, 130, 0.45);
    stroke-width: 0.4;
    stroke-linejoin: round;
    filter: drop-shadow(0 1px 1px rgba(0, 0, 0, 0.35));
    transition: fill var(--transition-fast), stroke var(--transition-fast);
  }

  .map-hotspot:hover {
    transform: translate(-50%, -50%) scale(1.25);
    z-index: 15;
  }

  .map-hotspot:hover .map-hotspot__shield {
    fill: rgba(60, 50, 40, 0.95);
    stroke: rgba(220, 185, 130, 0.8);
  }

  .map-hotspot__label {
    position: absolute;
    top: 22px;
    left: 50%;
    transform: translateX(-50%) translateY(-4px);
    font-family: var(--font-heading);
    font-size: 0.7rem;
    font-weight: 600;
    color: var(--color-text-heading);
    background: rgba(59, 50, 40, 0.9);
    padding: 2px 8px;
    border-radius: 4px;
    white-space: nowrap;
    opacity: 0;
    transition: all var(--transition-fast);
    pointer-events: auto;
    border: 1px solid var(--color-border);
  }

  .map-hotspot:hover .map-hotspot__label {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
  }

  /* --- Controls --- */
  .map-controls {
    position: absolute;
    bottom: var(--space-lg);
    right: var(--space-lg);
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
    z-index: 20;
  }

  .map-controls__btn {
    width: 36px;
    height: 36px;
    border-radius: var(--border-radius);
    border: 1px solid var(--color-border);
    background: rgba(59, 50, 40, 0.9);
    color: var(--color-text);
    font-size: 1.2rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all var(--transition-fast);
  }

  .map-controls__btn:hover {
    border-color: var(--color-green-dark);
    box-shadow: var(--glow-green);
    color: var(--color-text-heading);
  }

  /* --- Tooltip (for touch devices) --- */
  .map-tooltip {
    display: none;
    position: absolute;
    z-index: 30;
    background: rgba(59, 50, 40, 0.95);
    border: 1px solid var(--color-gold);
    border-radius: var(--border-radius);
    padding: var(--space-sm) var(--space-md);
    font-family: var(--font-heading);
    font-size: 0.85rem;
    color: var(--color-text-heading);
    pointer-events: none;
    box-shadow: var(--glow-gold);
  }
</style>

<script>
  const container = document.getElementById('map-container')!;
  const wrapper = document.getElementById('map-wrapper')!;
  const mapImage = document.getElementById('map-image')! as HTMLImageElement;
  const zoomIn = document.getElementById('zoom-in')!;
  const zoomOut = document.getElementById('zoom-out')!;
  const zoomReset = document.getElementById('zoom-reset')!;

  let scale = 1;
  let panX = 0;
  let panY = 0;
  let isDragging = false;
  let startX = 0;
  let startY = 0;

  function getImageFrame() {
    const wrapperWidth = wrapper.clientWidth;
    const wrapperHeight = wrapper.clientHeight;

    const imageRatio = mapImage.naturalWidth > 0 && mapImage.naturalHeight > 0
      ? mapImage.naturalWidth / mapImage.naturalHeight
      : wrapperWidth / wrapperHeight;
    const wrapperRatio = wrapperWidth / wrapperHeight;

    let width;
    let height;
    let left;
    let top;

    if (wrapperRatio > imageRatio) {
      height = wrapperHeight;
      width = height * imageRatio;
      left = (wrapperWidth - width) / 2;
      top = 0;
    } else {
      width = wrapperWidth;
      height = width / imageRatio;
      left = 0;
      top = (wrapperHeight - height) / 2;
    }

    return { left, top, width, height };
  }

  function positionHotspots() {
    const frame = getImageFrame();
    wrapper.querySelectorAll('.map-hotspot').forEach((hotspot) => {
      const el = hotspot as HTMLElement;
      const mapX = Number(el.dataset.mapX || '0');
      const mapY = Number(el.dataset.mapY || '0');
      el.style.left = `${frame.left + (mapX / 100) * frame.width}px`;
      el.style.top = `${frame.top + (mapY / 100) * frame.height}px`;
      el.classList.add('map-hotspot--ready');
    });
  }

  function updateTransform() {
    wrapper.style.transform = `translate(${panX}px, ${panY}px) scale(${scale})`;
  }

  zoomIn.addEventListener('click', () => {
    scale = Math.min(scale * 1.3, 5);
    updateTransform();
  });

  zoomOut.addEventListener('click', () => {
    scale = Math.max(scale / 1.3, 0.5);
    updateTransform();
  });

  zoomReset.addEventListener('click', () => {
    scale = 1;
    panX = 0;
    panY = 0;
    updateTransform();
    positionHotspots();
  });

  // Mouse wheel zoom
  container.addEventListener('wheel', (e) => {
    e.preventDefault();
    const factor = e.deltaY < 0 ? 1.1 : 0.9;
    scale = Math.min(Math.max(scale * factor, 0.5), 5);
    updateTransform();
  }, { passive: false });

  // Pan via drag
  container.addEventListener('mousedown', (e) => {
    if ((e.target as HTMLElement).closest('.map-hotspot') || (e.target as HTMLElement).closest('.map-controls__btn')) return;
    isDragging = true;
    startX = e.clientX - panX;
    startY = e.clientY - panY;
  });

  window.addEventListener('mousemove', (e) => {
    if (!isDragging) return;
    panX = e.clientX - startX;
    panY = e.clientY - startY;
    updateTransform();
  });

  window.addEventListener('mouseup', () => {
    isDragging = false;
  });

  // Touch support
  let lastTouchDist = 0;
  container.addEventListener('touchstart', (e) => {
    if (e.touches.length === 1) {
      isDragging = true;
      startX = e.touches[0].clientX - panX;
      startY = e.touches[0].clientY - panY;
    } else if (e.touches.length === 2) {
      isDragging = false;
      lastTouchDist = Math.hypot(
        e.touches[0].clientX - e.touches[1].clientX,
        e.touches[0].clientY - e.touches[1].clientY
      );
    }
  }, { passive: true });

  container.addEventListener('touchmove', (e) => {
    if (e.touches.length === 1 && isDragging) {
      panX = e.touches[0].clientX - startX;
      panY = e.touches[0].clientY - startY;
      updateTransform();
    } else if (e.touches.length === 2) {
      const dist = Math.hypot(
        e.touches[0].clientX - e.touches[1].clientX,
        e.touches[0].clientY - e.touches[1].clientY
      );
      if (lastTouchDist > 0) {
        scale = Math.min(Math.max(scale * (dist / lastTouchDist), 0.5), 5);
        updateTransform();
      }
      lastTouchDist = dist;
    }
  }, { passive: true });

  container.addEventListener('touchend', () => {
    isDragging = false;
    lastTouchDist = 0;
  });

  if (mapImage.complete) {
    positionHotspots();
  } else {
    mapImage.addEventListener('load', positionHotspots);
  }

  window.addEventListener('resize', positionHotspots);

</script>
